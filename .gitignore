# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool
*.out
coverage.txt
coverage.html

# Build directory
bin/*
!bin/.gitkeep
build/
dist/
houndoom
houndoom-*
ref/*
ref_bitrix/

# IDEs
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Configuration
houndoom.yaml
*.local.yaml

# Reports
.reports/

# Claude artifacts
.claude/artifacts/
.claude/settings.local.json

# Whitelist databases
*.db
!houndoom-whitelist.db

# Logs
*.log

# Temporary files
tmp/
temp/

# Agentless remote-scan: embedded bundled binaries.
# The generic 'dist/' rule above would hide the go:embed placeholder directory;
# re-include it so the committed README.md keeps the dir present for compilation,
# but keep the actual built linux binaries (placed by the release build) ignored.
!internal/remote/binaries/dist/
internal/remote/binaries/dist/houndoom-linux-*

# Local engagement output (reports may contain client code)
.houndoom/

# Go workspace file
go.work

# Dependencies
vendor/
